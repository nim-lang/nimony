
let x: int64 = 1
var y: int64 = 12
proc foo(x: int64): int64 =
  var result: int64
  var s: int64 = x
  s = 12
  result = s
  return result

discard foo(2)
var s: seq = @([1, 2, 3])
write stdout, s[0]
write stdout, '\n'
type
  Foo = object
    id: int64
proc =destroy(x: Foo) =
  discard

block:
  var m: Foo = Foo(id: 12)
  =destroy(m)

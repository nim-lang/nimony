tdoc_smoke.html: <em>italic</em>
tdoc_smoke.html: <a href="https://example.com">
tdoc_smoke.html: <table>
tdoc_smoke.html: <pre class="code">

# --- Per-decl doc renders markdown too ---
tdoc_smoke.html: <div class="doc">
tdoc_smoke.html: Returns

